#include <iostream>
using namespace std;
int main(void)
{
    int N,arr[N];
    cin>>N;
    int i=0;
    while(N--)
    {
       int A,B;
       cin>>A>>B;
       arr[i]=A+B;
       i++;
    }
    for(int i=0;i<N;i++)
    {
        cout<<arr[i]<<" ";
    }
    return 0;
}
